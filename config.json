{
  "plugins": [
    "./src/plugins/auth/auth.plugin.ts",
    "./src/plugins/interfaces/interfaces.plugin.ts",
    "./src/plugins/tools/tools.plugin.ts",
    "./src/plugins/memory/memory.plugin.ts",
    "./src/plugins/cognitive/cognitive.plugin.ts",
    "./src/plugins/workflows/workflows.plugin.ts",
    "./src/plugins/observability/observability.plugin.ts",
    "./src/plugins/notebook/notebook.plugin.ts",
    "./src/plugins/googleapis/googleapis.plugin.ts"
  ],
  "config": {
    "auth": {
      "rpId": "${AUTH_RPID:-localhost}",
      "rpName": "Rorschach",
      "origin": "${AUTH_ORIGIN:-http://localhost:3000}",
      "baseUrl": "${AUTH_ORIGIN:-http://localhost:3000}"
    },
    "interfaces": {
      "http": {
        "port": "${PORT:-3000}"
      },
      "signal": {
        "host": "127.0.0.1",
        "port": "7583"
      }
    },
    "tools": {
      "webSearch": {
        "apiKey": "${BRAVESEARCH_API_KEY}",
        "count": 20
      },
      "bash": {
        "cwd": "/workspace"
      },
      "visionActor": {
        "model": "google/gemini-3-pro-image-preview"
      },
      "audioActor": {
        "ttsModel": "google/gemini-3.1-flash-tts-preview",
        "sttModel": "google/chirp-3",
        "voice": "alloy"
      },
      "videoActor": {
        "model": "google/veo-3.1-lite",
        "aspectRatio": "16:9",
        "duration": 4,
        "resolution": "720p",
        "pollIntervalMs": 5000,
        "pollTimeoutMs": 600000
      }
    },
    "cognitive": {
      "workPath": "workspace/history",
      "llmProvider": {
        "apiKey": "${OPENROUTER_API_KEY}",
        "reasoning": {
          "enabled": true,
          "effort": "medium"
        }
      },
      "chatbot": {
        "systemPrompt": "You're the user perfect mirror. You always reflect the tone and style you perceive.",
        "model": "google/gemini-3.5-flash",
        "toolFilter": {
          "deny": [
            "bash",
            "write"
          ]
        }
      },
      "session": {
        "historyWindowHours": 2
      },
      "userContext": {
        "model": "deepseek/deepseek-v4-flash",
        "intervalMs": 60000
      }
    },
    "memory": {
      "workPath": "workspace/memory",
      "kgraph": {
        "embeddingModel": "perplexity/pplx-embed-v1-0.6b",
        "embeddingDimensions": 768,
        "cosineSimilarityThreshold": 0.6,
        "rerankerModel": "cohere/rerank-4-pro"
      },
      "system": {
        "model": "google/gemini-3.1-flash-lite",
        "consolidationIntervalMs": 3600000,
        "contextIntervalMs": 3600000
      }
    },
    "workflows": {
      "plansDir": "workspace/plans",
      "executor": {
        "model": "z-ai/glm-5.1",
        "maxToolLoops": 10
      },
      "planner": {
        "model": "z-ai/glm-5.1",
        "maxToolLoops": 10,
        "toolFilter": {
          "allow": [
            "web_search",
            "fetch_file",
            "switch_mode"
          ]
        }
      }
    },
    "notebook": {
      "notebookDir": "workspace/notebook",
      "agentModel": "minimax/minimax-m2.7",
      "maxToolLoops": 10
    },
    "googleapis": {
      "clientId": "${GOOGLE_CLIENT_ID}",
      "clientSecret": "${GOOGLE_CLIENT_SECRET}",
      "baseUrl": "https://rorschach.bot",
      "agentModel": "google/gemini-3.1-flash-lite",
      "maxToolLoops": 10
    },
    "observability": {
      "jsonlLogger": {
        "filePath": "workspace/observability/logs/rorschach-{date}.jsonl",
        "minLevel": "debug",
        "flushIntervalMs": 300000
      },
      "metrics": {
        "intervalMs": 5000
      },
      "traceRecorder": {
        "tracesDir": "workspace/observability/traces"
      },
      "costTracker": {
        "costsDir": "workspace/observability/costs",
        "flushIntervalMs": 300000
      }
    }
  }
}
