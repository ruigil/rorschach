{
  "plugins": [
    "./src/plugins/interfaces/interfaces.plugin.ts",
    "./src/plugins/tools/tools.plugin.ts",
    "./src/plugins/memory/memory.plugin.ts",
    "./src/plugins/cognitive/cognitive.plugin.ts",
    "./src/plugins/observability/observability.plugin.ts",
    "./src/plugins/notebook/notebook.plugin.ts"
  ],
  "config": {
    "interfaces": {
      "http": {
        "port": "${PORT:-3000}"
      },
      "signal": {
        "host": "127.0.0.1",
        "port": "7583",
        "groupId": "77CjSqNjZUanJ4oMTQRkhQKqPZM1WKnEZ55wKpaAbuo="
      }
    },
    "tools": {
      "webSearch": {
        "apiKey": "${BRAVESEARCH_API_KEY}",
        "count": 20
      },
      "bash": {
        "cwd": "/workspace"
      },
      "visionActor": {
        "model": "google/gemini-3-pro-image-preview"
      },
      "audioActor": {
        "model": "openai/gpt-audio",
        "voice": "nova"
      }
    },
    "cognitive": {
      "llmProvider": {
        "apiKey": "${OPENROUTER_API_KEY}",
        "reasoning": {
          "enabled": true,
          "effort": "medium"
        }
      },
      "chatbot": {
        "systemPrompt": "You're the user perfect mirror. You always reflect the tone and style you perceive.",
        "model": "x-ai/grok-4.20",
        "historyWindow": 40,
        "toolFilter": {
          "deny": [
            "kgraph_query",
            "kgraph_write"
          ]
        }
      }
    },
    "memory": {
      "kgraph": {
        "dbPath": "./workspace/memory/kgraph"
      },
      "memory": {
        "model": "google/gemini-3.1-pro-preview",
        "userId": "rigel",
        "consolidationIntervalMs": 30000
      }
    },
    "notebook": {
      "notebookDir": "workspace/notebook",
      "agentModel": "google/gemini-3.1-pro-preview",
      "consolidationModel": "google/gemini-3.1-pro-preview",
      "consolidationIntervalMs": 604800000,
      "maxToolLoops": 10
    },
    "observability": {
      "jsonlLogger": {
        "filePath": "./logs/rorschach.jsonl",
        "minLevel": "debug",
        "flushIntervalMs": 300000
      },
      "metrics": {
        "intervalMs": 5000
      },
      "traceRecorder": {
        "tracesDir": "./traces"
      }
    }
  }
}
