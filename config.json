{
  "plugins": [
    "./src/plugins/interfaces/interfaces.plugin.ts",
    "./src/plugins/tools/tools.plugin.ts",
    "./src/plugins/cognitive/cognitive.plugin.ts",
    "./src/plugins/observability/observability.plugin.ts"
  ],
  "config": {
    "interfaces": {
      "http": { "port": "${PORT:-3000}" }
    },
    "tools": {
      "webSearch": {
        "apiKey": "${BRAVESEARCH_API_KEY}",
        "count": 20
      },
      "bash":{
        "cwd": "/home/rorschach"
      }
    },
    "cognitive": {
      "llmProvider": {
        "apiKey": "${OPENROUTER_API_KEY}",
        "model": "${OPENROUTER_MODEL:-x-ai/grok-4.1-fast}"
      },
      "chatbot": {
        "systemPrompt": "You're the user perfect mirror. You always reflect what you perceive."
      },
      "visionActor": {
        "model": "${OPENROUTER_VISION_MODEL:-openai/gpt-5.4-nano}"
      }
    },
    "observability": {
      "jsonlLogger": {
        "filePath": "./logs/app.jsonl",
        "minLevel": "debug",
        "flushIntervalMs": 300000
      },
      "metrics": {
        "intervalMs": 5000
      }
    }
  }
}
