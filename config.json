{
  "plugins": [
    "./src/plugins/interfaces/interfaces.plugin.ts",
    "./src/plugins/tools/tools.plugin.ts",
    "./src/plugins/memory/memory.plugin.ts",
    "./src/plugins/cognitive/cognitive.plugin.ts",
    "./src/plugins/workflows/workflows.plugin.ts",
    "./src/plugins/observability/observability.plugin.ts",
    "./src/plugins/notebook/notebook.plugin.ts",
    "./src/plugins/googleapis/googleapis.plugin.ts",
    "./src/plugins/coding/coding.plugin.ts"
  ],
  "config": {
    "auth": {
      "rpId": "${AUTH_RPID:-localhost}",
      "rpName": "Rorschach",
      "origin": "${AUTH_ORIGIN:-http://localhost:3000}",
      "baseUrl": "${AUTH_ORIGIN:-http://localhost:3000}"
    },
    "interfaces": {
      "http": {
        "port": "3000"
      },
      "signal": {
        "host": "127.0.0.1",
        "port": "7583"
      }
    },
    "tools": {
      "webSearch": {
        "apiKey": "${BRAVESEARCH_API_KEY}",
        "count": 20
      },
      "bash": {
        "cwd": "/workspace"
      },
      "vision": {
        "model": "nano-banana-2"
      },
      "audio": {
        "ttsModel": "tts-gemini-3-1-flash",
        "sttModel": "stt-xai-v1",
        "voice": "alloy"
      },
      "video": {
        "model": "veo3.1-fast-text-to-video",
        "aspectRatio": "16:9",
        "duration": 4,
        "resolution": "720p",
        "pollIntervalMs": 5000,
        "pollTimeoutMs": 600000
      }
    },
    "cognitive": {
      "llmProvider": {
        "provider": "venice",
        "apiKey": "VENICE_INFERENCE_KEY_TiRvmQoNWEFjIhhJIBQYBKVABBb34-clXSw97LUiJC",
        "reasoning": {
          "enabled": true,
          "effort": "medium"
        },
        "baseUrl": ""
      },
      "chatbot": {
        "systemPrompt": "You're the user perfect mirror. You always reflect the tone and style you perceive.",
        "model": "gemini-3-5-flash",
        "toolFilter": {
          "deny": [
            "bash",
            "write",
            "edit"
          ]
        }
      },
      "session": {
        "contextWindowHours": 2,
        "contextPath": "workspace/context"
      },
      "userContext": {
        "model": "deepseek-v4-flash",
        "intervalMs": 60000
      }
    },
    "memory": {
      "workPath": "workspace/memory",
      "kgraph": {
        "embeddingModel": "gemini-embedding-2-preview",
        "embeddingDimensions": 768,
        "cosineSimilarityThreshold": 0.6,
        "rerankerModel": ""
      },
      "system": {
        "model": "deepseek-v4-flash",
        "consolidationIntervalMs": 60000
      }
    },
    "workflows": {
      "workflowsDir": "workspace/workflows",
      "agent": {
        "model": "deepseek-v4-flash",
        "maxToolLoops": 10,
        "toolFilter": {
          "allow": [
            "switch_mode"
          ]
        }
      }
    },
    "notebook": {
      "notebookDir": "workspace/notebook",
      "agent": {
        "model": "google/gemini-3.5-flash",
        "maxToolLoops": 10
      }
    },
    "googleapis": {
      "clientId": "${GOOGLE_CLIENT_ID}",
      "clientSecret": "${GOOGLE_CLIENT_SECRET}",
      "baseUrl": "https://rorschach.bot",
      "agentModel": "gemini-3-5-flash",
      "maxToolLoops": 10
    },
    "observability": {
      "jsonlLogger": {
        "filePath": "workspace/observability/logs/rorschach-{date}.jsonl",
        "minLevel": "debug",
        "flushIntervalMs": 300000
      },
      "metrics": {
        "intervalMs": 5000
      },
      "traceRecorder": {
        "tracesDir": "workspace/observability/traces"
      },
      "costTracker": {
        "costsDir": "workspace/observability/costs",
        "flushIntervalMs": 300000
      }
    },
    "coding": {
      "projectRoot": "/home/rigel/rorschach/src",
      "projectMount": "/rorschach",
      "workspaceDir": "workspace",
      "artifactsDir": "workspace/artifacts",
      "coding": {
        "model": "deepseek-v4-pro",
        "maxToolLoops": 25
      },
      "docs": {
        "model": "deepseek-v4-pro",
        "maxToolLoops": 30
      }
    }
  }
}
