{
  "name": "rorschach",
  "module": "index.ts",
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/jsdom": "^28.0.3",
    "jsdom": "^29.1.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "private": true,
  "scripts": {
    "clean": "rm -rf dist",
    "copy:assets": "mkdir -p dist/public && cp -r src/plugins/interfaces/public/* dist/public",
    "build:frontend": "bun build src/frontend/rorschach.ts --outfile dist/public/rorschach.js --minify",
    "build:backend": "bun build src/index.ts --outfile dist/index.js",
    "build": "bun run clean && bun run copy:assets && bun run build:frontend && bun run build:backend",
    "dev:frontend": "bun build src/frontend/rorschach.ts --outfile src/plugins/interfaces/public/rorschach.js --watch",
    "dev:backend": "bun run --watch src/index.ts",
    "dev": "bun run dev:frontend & bun run dev:backend",
    "rorschach": "bun run build && bun run dist/index.js",
    "test": "bun test",
    "typecheck": "bun tsc --noEmit",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage"
  },
  "type": "module",
  "dependencies": {
    "@grafeo-db/js": "^0.5.42",
    "cron-parser": "^5.5.0",
    "googleapis": "^171.4.0",
    "just-bash": "^3.0.1",
    "lit": "^3.3.3",
    "unpdf": "^1.6.2"
  }
}
